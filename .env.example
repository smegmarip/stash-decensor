# Stash configuration
STASH_URL=http://host.docker.internal:9999
# STASH_API_KEY=your-api-key-here  # Optional: only needed if Stash requires authentication

# Media path (shared volume with Stash)
MEDIA_PATH=/mnt/user/media

# Tag configuration (optional - Stash tag IDs)
CENSORED_TAG_ID=
DECENSORED_TAG_ID=

# Lada settings (optional - defaults shown)
ENCODING_PRESET=hevc-nvidia-gpu-hq
MOSAIC_DETECTION_MODEL=v2  # Options: v2, v4-fast, v4-accurate
# MAX_CLIP_LENGTH=180
# FP16=true
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True  # Reduces GPU memory fragmentation on long videos

# Worker settings
WORKER_CONCURRENCY=1
JOB_TIMEOUT=7200

# Cache settings
CACHE_TTL=86400

# Docker network name
DOCKER_NETWORK=stash-decensor-network

# External ports (customize if needed)
API_PORT=7030
UI_PORT=7031
